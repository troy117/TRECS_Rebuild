{
  "name": "trecs-js",
  "version": "0.1.0",
  "private": true,
  "description": "TRECS JavaScript rebuild prototype",
  "main": "src/main/main.js",
  "build": {
    "appId": "com.islandphotography.trecs",
    "productName": "TRECS",
    "asar": false,
    "directories": {
      "output": "../build/single"
    },
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../database",
        "to": "database",
        "filter": [
          "schema.sql",
          "product_seed.sql",
          "apply_product_aliases.sql"
        ]
      },
      {
        "from": "../JARS",
        "to": "JARS"
      },
      {
        "from": "../tools",
        "to": "tools",
        "filter": [
          "**/*.java",
          "**/*.class",
          "**/*.js"
        ]
      },
      {
        "from": "../Templates/FALL",
        "to": "Templates/FALL",
        "filter": [
          "*.jpg"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "TRECS-Portable.exe"
    }
  },
  "scripts": {
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-electron.ps1",
    "build:portable": "node scripts/build-portable.js",
    "check": "node scripts/check-files.js",
    "check:db": "node scripts/check-db.js",
    "check:bridge": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-electron-bridge.ps1",
    "check:ui": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-package-editor-ui.ps1",
    "check:units": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-picture-units.ps1",
    "check:render-ui": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-unit-render-ui.ps1",
    "check:composites": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-composite-builder-ui.ps1",
    "check:production": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-production-workflows-ui.ps1",
    "check:events": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-event-workflow-ui.ps1"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5"
  }
}
